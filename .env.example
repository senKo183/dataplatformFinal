# Sao chép file này thành .env và điền giá trị thực
# cp .env.example .env

# Claude API Key — lấy tại https://console.anthropic.com/
CLAUDE_API_KEY=sk-ant-...

# DeepSeek — https://platform.deepseek.com/
DEEPSEEK_API_KEY=sk-...

# Google AI Studio (Gemini) — https://aistudio.google.com/apikey
GOOGLE_API_KEY=
# Ví dụ: gemini-2.0-flash, gemini-1.5-flash
GEMINI_MODEL=gemini-2.0-flash

# Script demo giữa kỳ: gemini | deepseek | claude
DEMO_LLM_PROVIDER=gemini

# Vnstock ecosystem (hạn mức / tính năng nâng cao — xem docs vnstock)
# Không commit giá trị thật; chỉ điền trong file .env local
VNSTOCK_API_KEY=vnstock_917a4a16f2efc39c6fd459080a50e9c6

# Airflow
AIRFLOW_UID=50000
AIRFLOW__CORE__FERNET_KEY=
